# Supabase — set USE_REAL_DATA=true when configured
USE_REAL_DATA=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth (Phase 3) — disabled by default for safe local dev
ADMIN_AUTH=false
# Comma-separated bootstrap emails (optional, until admin_members is seeded)
# ADMIN_ALLOWED_EMAILS=admin@ltprotect.fr

# ---------------------------------------------------------------------------
# Email — production transactional sending (pré-inscriptions, devis, contact)
# Without a configured provider, emails are logged as skipped (workflows unchanged).
# ---------------------------------------------------------------------------
#
# Required for all providers:
#   O2Switch SMTP: use the cPanel mailbox that owns the domain (contact@)
EMAIL_FROM=contact@ltpformation.fr
EMAIL_FROM_NAME=LT Protect Formation
# Or as a single RFC value:
# EMAIL_FROM=LT Protect Formation <contact@ltpformation.fr>
#
# Reply-To on visitor-facing admin emails (public contact address)
EMAIL_REPLY_TO=contact@ltpformation.fr
# Internal inbox for new form submission alerts (not shown publicly)
EMAIL_NOTIFICATION_TO=ltprotect.formation@gmail.com
#
# Force SMTP on O2Switch hosting (required if RESEND_API_KEY is also present)
EMAIL_PROVIDER=smtp
#
# --- Option A: Resend (recommended) ---
# 1. Add and verify domain ltpformation.fr in Resend (SPF + DKIM DNS records)
# 2. Create an API key with send permission
RESEND_API_KEY=
#
# --- Option B: SMTP (Brevo, OVH, Google Workspace, hosting provider, etc.) ---
# Brevo example:
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-brevo-login-email
#   SMTP_PASSWORD=your-brevo-smtp-key
#
# O2Switch (cPanel) — port 465 SSL (recommended):
#   SMTP_HOST=yourcluster.o2switch.net
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=contact@ltpformation.fr
#   SMTP_PASSWORD=your-cpanel-mailbox-password
# Optional if SMTP_HOST is ltpformation.fr but TLS cert is for *.o2switch.net:
#   SMTP_TLS_SERVERNAME=yourcluster.o2switch.net
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

# Storage — required when USE_REAL_DATA=true (document uploads)
# 1. Run lib/db/migrations/002_entity_documents.sql + 003 + schema entity_documents table
# 2. Run lib/db/migrations/005_storage_bucket.sql (creates private bucket)
# 3. Bucket name: ltp-documents (private — downloads via /admin/documents/[id]/download)
# 4. Uploads use SUPABASE_SERVICE_ROLE_KEY server-side (no public upload policy needed)
# Folders: preinscriptions/, devis/, messages/

# Public site URL (canonical links, SEO, email logo asset URL)
NEXT_PUBLIC_SITE_URL=https://ltpformation.fr
